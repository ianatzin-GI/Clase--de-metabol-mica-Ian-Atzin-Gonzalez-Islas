# Grupo: "2"
# Práctica 4: qPCR y análisis absoluto
install.packages("pacman")
#pacman llama a otros paquetes, y si no estan, los instala
library(pacman)
p_load("vroom", # llamar base de datos
       "dplyr", # facilita el manejo de datos
       "ggplot2", "tidyr") #graficar

Amplif  <- vroom(file="https://raw.githubusercontent.com/ianatzin-GI/Clase--de-metabol-mica-Ian-Atzin-Gonzalez-Islas/refs/heads/main/Datos%20Curva%20G1%20y%20G2.csv")
head (Amplif)
Datos_long <- Amplif %>% # %>% significa que la base de datos 
  pivot_longer(cols = -Cycle, names_to = "Muestra", values_to = "Fluorescencia")

Datos_G2 <- Datos_long %>%
  filter(grepl("G2", Muestra)) 

grafica_G2 <- ggplot(Datos_G2, aes(x = Cycle, y = Fluorescencia, color = Muestra)) +
  geom_line(size = 1.2, color = "#E4007C") +
  geom_point(size = 1.5, color = "#E4007C") +
  labs(x = "Ciclos",
       y = "Fluorescencia",
       title = "Curva de amplificación RT-qPCR",
       subtitle = "Práctica 4: Grupo G2-M",
       caption = "Diseño: JIF") +
  theme_classic()

grafica_G2

# Guardar la gráfica
ggsave("Curva_Amplificacion_G2.png", grafica_G2, width = 7, height = 5, dpi = 300)
